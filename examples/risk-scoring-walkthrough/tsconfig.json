{
  "compilerOptions": {
    "allowJs": false,
    "esModuleInterop": true,
    "lib": ["dom", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "types": ["bun", "node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
