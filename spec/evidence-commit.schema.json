{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec.veritio.local/evidence-commit.schema.json",
  "title": "Veritio EvidenceCommit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recordType",
    "schemaVersion",
    "commitId",
    "streamId",
    "sequence",
    "previousCommitHash",
    "members",
    "recordCount",
    "recordsRoot",
    "canonicalization",
    "hashAlgorithm",
    "treeAlgorithm",
    "committedAt",
    "hash"
  ],
  "properties": {
    "recordType": {
      "const": "evidence.commit"
    },
    "schemaVersion": {
      "const": "2026-06-23"
    },
    "commitId": {
      "type": "string",
      "minLength": 1
    },
    "streamId": {
      "type": "string",
      "minLength": 1
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "previousCommitHash": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      ]
    },
    "members": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "recordType", "recordId", "recordHash"],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 0
          },
          "recordType": {
            "type": "string",
            "enum": [
              "audit.record",
              "evidence.edge.record",
              "entity.revision.record",
              "activity.record",
              "assertion.record",
              "change.record"
            ]
          },
          "recordId": {
            "type": "string",
            "minLength": 1
          },
          "recordHash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    },
    "recordCount": {
      "type": "integer",
      "minimum": 1
    },
    "recordsRoot": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "canonicalization": {
      "const": "veritio-json-v1"
    },
    "hashAlgorithm": {
      "const": "sha256"
    },
    "treeAlgorithm": {
      "const": "veritio-merkle-v1"
    },
    "committedAt": {
      "type": "string",
      "format": "date-time"
    },
    "hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
