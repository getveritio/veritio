{
  "name": "metadata-redaction-v1",
  "cases": [
    {
      "name": "redacts sensitive keys recursively and keeps stable identifiers",
      "metadata": {
        "apiToken": "token_fixture_value",
        "authorization": "Bearer fixture-token",
        "contactEmail": "member@example.invalid",
        "phoneNumber": "+15550100",
        "safeCount": 2,
        "stableRef": "usr_fixture_123",
        "nested": {
          "secretNote": "fixture secret",
          "workspaceRef": "wks_fixture_456"
        },
        "tags": [
          "audit",
          "invite"
        ]
      },
      "expectedMetadata": {
        "apiToken": "[redacted]",
        "authorization": "[redacted]",
        "contactEmail": "[redacted]",
        "phoneNumber": "[redacted]",
        "safeCount": 2,
        "stableRef": "usr_fixture_123",
        "nested": {
          "secretNote": "[redacted]",
          "workspaceRef": "wks_fixture_456"
        },
        "tags": [
          "audit",
          "invite"
        ]
      }
    },
    {
      "name": "sanitizes digest envelopes without preserving sibling raw values",
      "metadata": {
        "customerEmail": {
          "algorithm": "hmac-sha256",
          "digest": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "keyVersion": "tenant-key-7",
          "raw": "buyer@example.com",
          "hmacKey": "test-hmac-secret"
        },
        "contactEmailInvalidDigest": {
          "algorithm": "hmac-sha256",
          "digest": "sha256:not-a-digest",
          "keyVersion": "tenant-key-7",
          "raw": "buyer@example.com"
        },
        "safeDigestEnvelope": {
          "captureMode": "content_digest",
          "digest": "sha256:bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
          "raw": "buyer@example.com",
          "key": "test-hmac-secret"
        }
      },
      "expectedMetadata": {
        "customerEmail": {
          "algorithm": "hmac-sha256",
          "digest": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "keyVersion": "tenant-key-7"
        },
        "contactEmailInvalidDigest": "[redacted]",
        "safeDigestEnvelope": {
          "captureMode": "content_digest",
          "digest": "sha256:bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
        }
      }
    }
  ]
}
