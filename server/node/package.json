{
  "name": "@veritio/server",
  "version": "0.0.1",
  "description": "Local and self-hosted Veritio Node server for Workbench, MCP, graph query, verification, and export preview.",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getveritio/veritio.git",
    "directory": "server/node"
  },
  "keywords": [
    "audit-trail",
    "evidence",
    "nodejs",
    "server",
    "records-of-processing"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun run --cwd ../../sdks/typescript build && node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "typecheck": "bun run --cwd ../../sdks/typescript build && node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "test": "bun run --cwd ../../sdks/typescript build && bun test src"
  },
  "dependencies": {
    "@veritio/core": "workspace:*"
  }
}
