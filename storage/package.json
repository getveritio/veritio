{
  "name": "@veritio/storage",
  "version": "0.0.1",
  "description": "Host-injected storage adapters for Veritio audit trail evidence.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getveritio/veritio.git",
    "directory": "storage"
  },
  "keywords": [
    "audit-trail",
    "evidence",
    "tamper-evident",
    "postgres",
    "mysql",
    "mongodb",
    "redis"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./conformance": {
      "types": "./dist/conformance.d.ts",
      "import": "./dist/conformance.js",
      "default": "./dist/conformance.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run --cwd ../sdks/typescript build && node ../node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "typecheck": "bun run --cwd ../sdks/typescript build && node ../node_modules/typescript/bin/tsc -p tsconfig.build.json --noEmit",
    "test": "bun run --cwd ../sdks/typescript build && bun test src integration"
  },
  "peerDependencies": {
    "@veritio/core": ">=0.0.0"
  },
  "devDependencies": {
    "@veritio/core": "workspace:*",
    "mongodb": "^7.3.0",
    "mysql2": "^3.22.5",
    "pg": "^8.21.0"
  }
}
