{
  "name": "@veritio/better-auth",
  "version": "0.0.2",
  "description": "Better Auth adapter for recording Veritio audit trail evidence from server-side auth lifecycle events.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getveritio/veritio.git",
    "directory": "adapters/better-auth"
  },
  "keywords": [
    "better-auth",
    "auth",
    "audit-trail",
    "evidence",
    "tamper-evident",
    "records-of-processing",
    "typescript"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/index.js",
    "dist/index.js.map",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "test": "bun test src"
  },
  "peerDependencies": {
    "@veritio/core": ">=0.0.0",
    "better-auth": ">=1.6.18"
  },
  "peerDependenciesMeta": {
    "better-auth": {
      "optional": true
    }
  },
  "devDependencies": {
    "@veritio/core": "workspace:*"
  }
}
