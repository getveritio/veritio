{
  "name": "@veritio/tanstack-start",
  "version": "0.0.0",
  "description": "TanStack Start adapter for recording Veritio audit trail evidence from server functions and route handlers.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getveritio/veritio.git",
    "directory": "adapters/tanstack-start"
  },
  "keywords": [
    "tanstack-start",
    "audit-trail",
    "evidence",
    "server-functions",
    "typescript"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/index.js",
    "dist/index.js.map",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "test": "bun test src"
  },
  "peerDependencies": {
    "@tanstack/react-start": "*",
    "@veritio/core": ">=0.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-start": {
      "optional": true
    }
  },
  "devDependencies": {
    "@veritio/core": "workspace:*"
  }
}
